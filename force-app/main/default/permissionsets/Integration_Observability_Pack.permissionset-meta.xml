<?xml version="1.0" encoding="UTF-8"?>
<PermissionSet xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>Integration Observability Pack</label>

    <!-- Apex class access -->
    <classAccesses><apexClass>IO_AppController</apexClass><enabled>true</enabled></classAccesses>
    <classAccesses><apexClass>IO_FileService</apexClass><enabled>true</enabled></classAccesses>
    <classAccesses><apexClass>IO_ReplayService</apexClass><enabled>true</enabled></classAccesses>
    <classAccesses><apexClass>IO_WebhookIntake</apexClass><enabled>true</enabled></classAccesses>
    <classAccesses><apexClass>IO_Correlation</apexClass><enabled>true</enabled></classAccesses>
    <classAccesses><apexClass>IO_WebhookSecrets</apexClass><enabled>true</enabled></classAccesses>

    <!-- Tab visibility -->
    <tabSettings>
        <tab>Integration_Observability_Pack</tab>
        <visibility>Visible</visibility>
    </tabSettings>

    <!-- Standard object permissions used by the inbox (Files) -->
    <objectPermissions><object>ContentVersion</object><allowCreate>true</allowCreate><allowRead>true</allowRead><allowEdit>false</allowEdit><allowDelete>false</allowDelete><viewAllRecords>false</viewAllRecords><modifyAllRecords>false</modifyAllRecords></objectPermissions>
    <objectPermissions><object>ContentDocument</object><allowCreate>false</allowCreate><allowRead>true</allowRead><allowEdit>false</allowEdit><allowDelete>false</allowDelete><viewAllRecords>false</viewAllRecords><modifyAllRecords>false</modifyAllRecords></objectPermissions>
    <objectPermissions><object>ContentDocumentLink</object><allowCreate>true</allowCreate><allowRead>true</allowRead><allowEdit>false</allowEdit><allowDelete>false</allowDelete><viewAllRecords>false</viewAllRecords><modifyAllRecords>false</modifyAllRecords></objectPermissions>

    <!-- Required for Tooling/REST calls from UI and to view Setup inventory -->
    <userPermissions><name>ApiEnabled</name><enabled>true</enabled></userPermissions>
    <userPermissions><name>ViewSetup</name><enabled>true</enabled></userPermissions>
</PermissionSet>
